# =============================================================================
# E-tab Backend - Production Environment Template
# Copy this file to .env and fill in your actual values
# NEVER commit .env to git!
# =============================================================================

NODE_ENV=production
PORT=5000

# =============================================================================
# DATABASE - Use connection string from your hosting provider
# Format: postgresql://user:password@host:port/database
# =============================================================================
DATABASE_URL=postgresql://username:password@host:5432/etab_production

# Or use individual settings (fallback if DATABASE_URL not set)
DB_USER=etab_user
DB_HOST=your-db-host.com
DB_NAME=etab_production
DB_PASSWORD=your_secure_db_password
DB_PORT=5432

# =============================================================================
# JWT CONFIGURATION - Generate strong secrets!
# Run: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# =============================================================================
JWT_SECRET=GENERATE_A_128_CHARACTER_HEX_STRING_HERE
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# =============================================================================
# CLOUDINARY - File Storage
# Get from: https://cloudinary.com/console
# =============================================================================
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# =============================================================================
# GOOGLE GEMINI AI - For AI Tutor
# Get from: https://makersuite.google.com/app/apikey
# =============================================================================
GEMINI_API_KEY=your_gemini_api_key

# =============================================================================
# FILE UPLOAD CONFIGURATION
# =============================================================================
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=52428800
ALLOWED_FILE_TYPES=pdf,doc,docx,ppt,pptx,xls,xlsx,mp4,webm,zip

# =============================================================================
# CORS - Your production frontend URL only!
# =============================================================================
FRONTEND_URL=https://yourdomain.com
CORS_ORIGIN=https://yourdomain.com

# =============================================================================
# RATE LIMITING (Production values)
# =============================================================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# =============================================================================
# EMAIL CONFIGURATION - SENDGRID (Recommended for Production)
# Sign up: https://signup.sendgrid.com/
# Create API Key: https://app.sendgrid.com/settings/api_keys
# =============================================================================
EMAIL_SERVICE=sendgrid
SENDGRID_API_KEY=SG.your_sendgrid_api_key_here

# Alternative: Gmail SMTP (for testing only, not recommended for production)
# EMAIL_SERVICE=gmail
# EMAIL_USER=your-email@gmail.com
# EMAIL_PASSWORD=your-16-char-app-password

# =============================================================================
# E-TAB CENTRAL EMAIL CONFIGURATION
# All emails sent from E-tab platform (not individual schools)
# =============================================================================

# From address (what users see in their inbox)
EMAIL_FROM_NAME=E-tab Education
EMAIL_FROM_ADDRESS=noreply@etab.co.za
EMAIL_SUPPORT_ADDRESS=support@etab.co.za
EMAIL_REPLY_TO=support@etab.co.za

# Legacy fallback (deprecated, use above)
# EMAIL_FROM=E-tab Education <noreply@etab.co.za>

# =============================================================================
# OPTIONAL: Redis (for session storage in production)
# REDIS_URL=redis://username:password@host:port

# OPTIONAL: Sentry (Error tracking)
# SENTRY_DSN=https://your-sentry-dsn

# =============================================================================
# SECURITY HEADERS
# =============================================================================
# Set to 'true' to enable additional security headers
ENABLE_SECURITY_HEADERS=true
